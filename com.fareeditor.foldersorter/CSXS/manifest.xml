<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.fareeditor.foldersorter" ExtensionBundleVersion="1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.fareeditor.foldersorter" Version="1.0" />
    <Extension Id="com.fareeditor.foldersorter.settings" Version="1.0" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[14.0,99.9]" />
      <Host Name="PPRO" Version="[14.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="6.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.fareeditor.foldersorter">
      <DispatchInfo>
        <Name>Folder Sorter</Name>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Folder Sorter</Menu>
          <Geometry>
            <Size>
              <Height>300</Height>
              <Width>250</Width>
            </Size>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
    <Extension Id="com.fareeditor.foldersorter.settings">
      <DispatchInfo>
        <Name>Folder Sorter</Name>
        <Resources>
          <MainPath>./client/settings.html</MainPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Modeless</Type>
          <Menu>Folder Sorter — Settings</Menu>
          <Geometry>
            <Size>
              <Height>540</Height>
              <Width>700</Width>
            </Size>
            <MinSize>
              <Height>400</Height>
              <Width>560</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
